# Copia a .env y rellena. .env está en .gitignore — NUNCA se sube.

# --- Supabase (validación de JWT de usuario) ---
# El backend NO necesita la service_role. Solo el secreto JWT o el JWKS URL
# para VERIFICAR firmas de tokens que el frontend ya emite.
SUPABASE_PROJECT_REF=rcaljqmibtkorcmdyqvg
SUPABASE_JWKS_URL=https://rcaljqmibtkorcmdyqvg.supabase.co/auth/v1/.well-known/jwks.json
# Fallback HS256 (proyectos viejos de Supabase usan un secreto simétrico):
SUPABASE_JWT_SECRET=

# --- CORS: SOLO el origen del frontend. Nada de "*". ---
ALLOWED_ORIGIN=https://imgoingsavage.github.io

# --- Cabecera de servicio compartida (defensa en profundidad tras el túnel) ---
# El frontend la añade en cada request; el túnel/WAF puede exigirla también.
SERVICE_TOKEN=cambia-esto-por-un-secreto-largo-aleatorio

# --- Qdrant local ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=cogito_biblioteca

# --- Ollama local ---
OLLAMA_URL=http://localhost:11434
OLLAMA_GEN_MODEL=deepseek-r1:1.5b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Concurrencia / cola ---
MAX_INFLIGHT=1            # workers de inferencia local simultáneos (i5: 1)
MAX_QUEUE=12             # jobs en cola antes de devolver 429
JOB_TIMEOUT_S=180        # corta un job de generación que se cuelga
USER_RATE_PER_MIN=6      # requests/min por usuario (anti-spam)
JOB_TTL_S=900            # un job terminado se purga a los 15 min

# --- Política pedagógica ---
# Generador para EVALUACION cuando NO hay Claude BYOK: "curated" usa solo
# pistas curadas (recomendado), "local" arriesga el 1.5B (no recomendado).
EVALUACION_FALLBACK=curated
